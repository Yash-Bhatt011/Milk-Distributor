<div class="container py-4">
  <!-- Dashboard Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 bg-primary text-white shadow">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h1 class="mb-0 fw-bold">Distributor Dashboard</h1>
              <p class="mb-0 opacity-75">Welcome back, <%= locals.user ? user.name : 'Distributor' %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Dashboard Stats -->
  <div class="row g-4 mb-4">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="dashboard-icon bg-primary text-white rounded-circle p-3 me-3">
              <i class="fas fa-truck fa-fw"></i>
            </div>
            <h5 class="card-title fw-bold mb-0">Today's Deliveries</h5>
          </div>
          <p class="display-4 fw-bold text-primary mb-3"><%= todaysDeliveries %></p>
          <div class="d-flex align-items-center text-muted small mb-3">
            <i class="fas fa-calendar-day me-2"></i>
            <span><%= new Date().toLocaleDateString() %></span>
          </div>
          <a href="/distributor/deliveries" class="btn btn-primary w-100">
            <i class="fas fa-clipboard-list me-2"></i>View All Deliveries
          </a>
        </div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="dashboard-icon bg-success text-white rounded-circle p-3 me-3">
              <i class="fas fa-users fa-fw"></i>
            </div>
            <h5 class="card-title fw-bold mb-0">Active Customers</h5>
          </div>
          <p class="display-4 fw-bold text-success mb-3"><%= activeCustomers %></p>
          <div class="d-flex align-items-center text-muted small mb-3">
            <i class="fas fa-chart-line me-2"></i>
            <span>Subscribed Users</span>
          </div>
          <a href="/distributor/customers" class="btn btn-success w-100">
            <i class="fas fa-user-cog me-2"></i>Manage Customers
          </a>
        </div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="dashboard-icon bg-warning text-white rounded-circle p-3 me-3">
              <i class="fas fa-rupee-sign fa-fw"></i>
            </div>
            <h5 class="card-title fw-bold mb-0">Pending Payments</h5>
          </div>
          <p class="display-4 fw-bold text-warning mb-3">₹<%= pendingPayments %></p>
          <div class="d-flex align-items-center text-muted small mb-3">
            <i class="fas fa-exclamation-circle me-2"></i>
            <span>Awaiting Collection</span>
          </div>
          <a href="/distributor/payments" class="btn btn-warning w-100">
            <i class="fas fa-file-invoice-dollar me-2"></i>View Payments
          </a>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100 dashboard-card">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="dashboard-icon bg-info text-white rounded-circle p-3 me-3">
              <i class="fas fa-chart-line fa-fw"></i>
            </div>
            <h5 class="card-title fw-bold mb-0">Monthly Revenue</h5>
          </div>
          <p class="display-4 fw-bold text-info mb-3">₹<%= monthlyRevenue %></p>
          <div class="d-flex align-items-center text-muted small mb-3">
            <i class="fas fa-calendar me-2"></i>
            <span>This Month's Earnings</span>
          </div>
          <a href="/distributor/revenue" class="btn btn-info w-100">
            <i class="fas fa-chart-bar me-2"></i>View Revenue Details
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Deliveries -->
  <div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white p-4 border-bottom">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
          <i class="fas fa-truck-loading me-2 text-primary"></i>Recent Deliveries
        </h5>
        <a href="/distributor/deliveries" class="btn btn-outline-primary btn-sm">
          View All <i class="fas fa-arrow-right ms-1"></i>
        </a>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr>
              <th class="ps-4">Customer</th>
              <th>Address</th>
              <th>Time</th>
              <th>Status</th>
              <th class="text-end pe-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentDeliveries && recentDeliveries.length > 0) { %>
              <% recentDeliveries.forEach(delivery => { %>
                <tr>
                  <td class="ps-4">
                    <div class="d-flex align-items-center">
                      <div class="avatar-circle bg-primary text-white me-3">
                        <%= delivery.customer.name.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <div class="fw-bold"><%= delivery.customer.name %></div>
                        <div class="small text-muted">#<%= delivery.customer._id.toString().slice(-6) %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="text-truncate" style="max-width: 250px;">
                      <i class="fas fa-map-marker-alt me-1 text-muted"></i>
                      <%= delivery.customer.address.street %>, <%= delivery.customer.address.city %>
                    </div>
                  </td>
                  <td>
                    <div>
                      <div><i class="far fa-calendar-alt me-1 text-muted"></i> <%= new Date(delivery.scheduledDate).toLocaleDateString() %></div>
                      <div class="small text-muted"><i class="far fa-clock me-1"></i> <%= new Date(delivery.scheduledDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></div>
                    </div>
                  </td>
                  <td>
                    <span class="badge rounded-pill bg-<%= 
                      delivery.status === 'delivered' ? 'success' : 
                      delivery.status === 'pending' ? 'warning' : 
                      'danger' %> py-2 px-3">
                      <i class="fas fa-<%= 
                        delivery.status === 'delivered' ? 'check-circle' : 
                        delivery.status === 'pending' ? 'clock' : 
                        'times-circle' %> me-1"></i>
                      <%= delivery.status %>
                    </span>
                  </td>
                  <td class="text-end pe-4">
                    <div class="btn-group">
                      <button class="btn btn-sm btn-outline-success" onclick="deliveryManager.updateStatus('<%= delivery._id %>', 'delivered')" <%= delivery.status === 'delivered' ? 'disabled' : '' %>>
                        <i class="fas fa-check me-1"></i> Complete
                      </button>
                      <button class="btn btn-sm btn-outline-danger" onclick="deliveryManager.updateStatus('<%= delivery._id %>', 'failed')" <%= delivery.status === 'failed' ? 'disabled' : '' %>>
                        <i class="fas fa-times me-1"></i> Failed
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-5">
                  <div class="empty-state">
                    <i class="fas fa-truck-loading text-muted mb-3" style="font-size: 3rem;"></i>
                    <h5>No Recent Deliveries</h5>
                    <p class="text-muted">No deliveries have been scheduled yet</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<style>
  .dashboard-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    font-size: 1.25rem;
    border-radius: 50%;
  }
  
  .dashboard-card {
    transition: transform 0.2s ease-in-out;
  }
  
  .dashboard-card:hover {
    transform: translateY(-5px);
  }
  
  .avatar-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-weight: bold;
  }
  
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  
  /* Animation for refresh button */
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .fa-spin {
    animation: spin 1s linear infinite;
  }
</style>

<script>
const deliveryManager = {
    csrfToken: document.querySelector('meta[name="csrf-token"]').getAttribute('content'),

    async updateStatus(id, status) {
        try {
            if (!confirm(`Are you sure you want to mark this delivery as ${status}?`)) {
                return;
            }

            const response = await fetch(`/distributor/deliveries/${id}/status`, {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'CSRF-Token': this.csrfToken
                },
                body: JSON.stringify({ 
                    status,
                    notes: status === 'failed' ? prompt('Please enter reason for failure:') : ''
                })
            });

            const data = await response.json();
            
            if (!response.ok) throw new Error(data.message || 'Failed to update status');
            
            showToast('success', `Delivery marked as ${status}`);
            setTimeout(() => window.location.reload(), 1000);
        } catch (err) {
            console.error('Error:', err);
            showToast('danger', err.message || 'Error updating delivery status');
        }
    }
};
</script>
